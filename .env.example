# ──────────────────────────────────────────────────────────────────────────────
# Hospital Operations Dashboard — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection string ───────────────────────────────────────────────
# Local development (default PostgreSQL install):
DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital_dashboard

# Railway example (copy from Railway dashboard → Variables):
# DATABASE_URL=postgresql://postgres:TOKEN@monorail.proxy.rlwy.net:PORT/railway

# ── Dashboard settings ─────────────────────────────────────────────────────────
# Set to "true" to enable Dash hot-reload in development
DASH_DEBUG=false

# Port (Railway sets this automatically; only needed for local override)
# PORT=8050
